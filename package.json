{
  "name": "agentdock",
  "displayName": "AgentDock",
  "description": "Kanban-style board for managing AI coding agent terminal sessions",
  "version": "0.1.1",
  "publisher": "trungsherlock2002",
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "resources/icons/agentdock.png",
  "categories": [
    "AI",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Trungsherlock/agent-dock.git"
  },
  "keywords": [
    "agent",
    "claude",
    "ai",
    "terminal",
    "kanban",
    "coding agents"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentdock",
          "title": "AgentDock",
          "icon": "resources/icons/agentdock.svg"
        }
      ]
    },
    "views": {
      "agentdock": [
        {
          "icon": "resources/icons/agentdock.png",
          "id": "agentdock.boardView",
          "name": "Agent Board",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "agentdock.newSession",
        "title": "New Agent Session",
        "icon": "$(add)"
      },
      {
        "command": "agentdock.endSession",
        "title": "End Session",
        "icon": "$(trash)"
      },
      {
        "command": "agentdock.renameSession",
        "title": "Rename Session"
      },
      {
        "command": "agentdock.focusSession",
        "title": "Switch Agent Session"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "agentdock.endSession",
          "when": "viewItem == session",
          "group": "inline"
        },
        {
          "command": "agentdock.renameSession",
          "when": "viewItem == session"
        },
        {
          "command": "agentdock.focusSession",
          "when": "viewItem == session",
          "group": "inline"
        }
      ]
    },
    "viewsWelcome": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build-webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-webview": "cd webview-ui && npm run build",
    "watch-webview": "cd webview-ui && npm run dev",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "overrides": {
    "diff": ">=8.0.3",
    "serialize-javascript": ">=6.0.2"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
